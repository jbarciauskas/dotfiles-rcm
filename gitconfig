[alias]
    co = checkout
    ci = commit
    st = status
    br = branch
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
    type = cat-file -t
    dump = cat-file -p[branch]
    autosetupmerge = true
    autosetuprebase = always
[push]
    default = simple
[core]
    precomposeunicode = false
    editor = /usr/bin/vim
    excludesfile = /Users/jbarciauskas/.gitignore_global
	hooksPath = /usr/local/dd/global_hooks
[user]
    name = Joel Barciauskas
    email = barciajo@gmail.com
[branch]
    autosetupmerge = true
    autosetuprebase = always
[maintenance]
	repo = /Users/joel.barciauskas/src/dd-source
